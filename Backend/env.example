# Repo path: Backend/.env.example  (UPDATED — PostgreSQL only)
# Copy this to Backend/.env and fill in your real values.
# Backend/.env is already covered by .gitignore — never commit real credentials.

# ---- Supabase PostgreSQL (required) ----
# Get this string from: Supabase Dashboard -> your project -> Project Settings
# -> Database -> Connection string -> URI tab.
# Supabase gives you a string starting "postgresql://" — change it to
# "postgresql+psycopg2://" so SQLAlchemy picks the right driver, keep everything else.
#
# Use the "Session pooler" connection string for a normal long-running backend
# process (this app). Use the "Transaction pooler" one instead only if you
# deploy the backend as serverless functions.
DATABASE_URL=postgresql+psycopg2://postgres:<YOUR-PASSWORD>@db.<YOUR-PROJECT-REF>.supabase.co:5432/postgres

UPLOAD_DIR=storage/uploads
MAX_UPLOAD_SIZE_MB=10

# ---- MobileSAM (optional) ----
# Path to the MobileSAM weights directory. Only override if you store weights
# in a non-standard location (e.g., a shared network drive).
# SAM_WEIGHTS_DIR=app/ml/sam/weights
